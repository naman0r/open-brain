# Supabase project URL (for API calls)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase API keys
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Postgres connection string (Session pooler or direct URI)
# Example:
# postgresql+psycopg://postgres.your_ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql+psycopg://user:password@host:6543/postgres

# App auth for local single-user access
OPEN_BRAIN_API_TOKEN=change-me

# Embeddings provider settings
# EMBEDDING_PROVIDER options: local | openai | auto
EMBEDDING_PROVIDER=local
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# Retrieval tuning
RETRIEVAL_SCORE_THRESHOLD=0.15
RETRIEVAL_MAX_TOP_K=50
